{
  "manifest_version": 2,
  "name": "ILIAS Download Companion",
  "version": "0.1.0",
  "description": "Update the current ILIAS course with PFERD.",
  "permissions": ["activeTab", "nativeMessaging", "notifications", "tabs"],
  "background": {
    "scripts": ["background.js"]
  },
  "browser_action": {
    "default_title": "Update this ILIAS course",
    "default_popup": "popup.html"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "ilias-download-companion@local",
      "strict_min_version": "109.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}
